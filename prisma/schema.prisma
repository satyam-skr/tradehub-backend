generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  OPEN
  PARTIAL
  FILLED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  wallet        Wallet?
  orders        Order[]
  stockHoldings StockHolding[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Decimal  @default(0)
  lockedBalance Decimal  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Stock {
  id       String  @id @default(uuid())
  symbol   String  @unique
  name     String
  exchange Decimal
}

model StockHolding {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  quantity  Int      @default(0)
  locked    Int      @default(0)
  avgPrice  Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, symbol])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  symbol         String
  side           OrderSide
  type           OrderType
  price          Decimal?
  quantity       Int
  filledQuantity Int         @default(0)
  status         OrderStatus @default(OPEN)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  buyTrades  Trade[] @relation("BuyOrder")
  sellTrades Trade[] @relation("SellOrder")
}

model Trade {
  id          String   @id @default(uuid())
  buyOrderId  String
  sellOrderId String
  symbol      String
  price       Decimal
  quantity    Int
  executedAt  DateTime @default(now())

  buyOrder  Order @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellOrder Order @relation("SellOrder", fields: [sellOrderId], references: [id])
}
