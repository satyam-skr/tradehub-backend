{
  "compilerOptions": {
    "rootDir": "./src",   
    "outDir": "./dist",       
    "module": "ES2020",
    "target": "ES2020",  
    "moduleResolution": "node",
    "types": ["node"],
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,    
  },
  "include": ["src/**/*.ts"]
}
